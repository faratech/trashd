# Maintainer: Faratech <dev@faratech.com>
pkgname=trashd
pkgver=0.1.0
pkgrel=1
pkgdesc='A Linux recycle bin that works in scripts, cron, and at the desktop'
arch=('x86_64' 'aarch64')
url='https://github.com/faratech/trashd'
license=('MIT')
depends=('gcc-libs')
makedepends=('rust' 'cargo')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$pkgname-$pkgver"
    cargo build --release --locked
}

check() {
    cd "$pkgname-$pkgver"
    cargo test --workspace --locked
}

package() {
    cd "$pkgname-$pkgver"
    make install DESTDIR="$pkgdir" PREFIX=/usr

    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
